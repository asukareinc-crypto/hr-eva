# ====================================================================
# HR EVA — 本番環境変数テンプレート
# Vercel の Environment Variables にコピーして使用してください。
# ====================================================================

# --- Database (Neon) ---
# Neon の "Connection string" をそのまま貼り付け。?sslmode=require は必須
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxx.ap-northeast-1.aws.neon.tech/neondb?sslmode=require

# --- Auth (NextAuth v5) ---
# 32文字以上のランダム文字列。生成: `openssl rand -base64 32`
AUTH_SECRET=__REPLACE_ME_WITH_openssl_rand_base64_32__
AUTH_URL=https://your-app.vercel.app
AUTH_TRUST_HOST=true

# --- Encryption (テナント API キーの暗号化マスター鍵) ---
# 32文字以上のランダム文字列。生成: `openssl rand -base64 48`
ENCRYPTION_KEY=__REPLACE_ME_WITH_openssl_rand_base64_48__

# --- Email (Resend) — テナント別キーが未設定時のフォールバック ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=HR EVA <noreply@your-domain.com>

# --- Runtime ---
NODE_ENV=production
